# ── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Banco de dados PostgreSQL ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clinic_saas
DB_USER=clinic_user
DB_PASSWORD=TROQUE_ESTA_SENHA_FORTE_AQUI

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERE_UM_SECRET_ALEATORIO_DE_64_BYTES_AQUI

# ── CORS ──────────────────────────────────────────────────────────────────────
# Domínio(s) permitido(s), separados por vírgula
CORS_ORIGIN=https://seu-dominio.com.br
