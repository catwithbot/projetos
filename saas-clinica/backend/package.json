{
  "name": "clinic-saas-backend",
  "version": "1.0.0",
  "description": "Backend para sistema de gestão de clínica",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --forceExit",
    "test:watch": "jest --watch --forceExit",
    "test:coverage": "jest --coverage --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["./tests/setup.js"],
    "testMatch": ["**/tests/**/*.test.js"],
    "verbose": true
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "express": "^5.0.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2"
  }
}
